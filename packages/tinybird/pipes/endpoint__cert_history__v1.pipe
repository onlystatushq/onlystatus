NODE cert_trend
SQL >
    SELECT
        toStartOfHour(fromUnixTimestamp64Milli(cronTimestamp)) AS time,
        monitorId,
        avg(certExpiryDays) AS avgExpiryDays,
        min(certValid) AS allValid
    FROM ping_response__v8
    WHERE
        monitorId = {{String(monitorId, '')}}
        AND certExpiryDays IS NOT NULL
        AND cronTimestamp >= {{Int64(fromTimestamp, 0)}}
    GROUP BY time, monitorId
    ORDER BY time ASC

TYPE endpoint
