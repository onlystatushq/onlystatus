# ─── Required ─────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Must be "true" for self-hosted deployments
SELF_HOST="true"

# ─── Authentication ───────────────────────────────────────
# Allow new user registration (set to false after initial setup)
ALLOW_PUBLIC_REGISTRATION=true

# TOTP 2FA encryption key (generate with: openssl rand -hex 32)
TOTP_ENCRYPTION_KEY=
TOTP_KEY_VERSION=v1

# ─── Internal Services (usually no changes needed) ────────
DATABASE_URL=http://libsql:8080
CHECKER_URL=http://checker:8080
WORKFLOWS_URL=http://workflows:3000
TINYBIRD_URL=http://tinybird-local:7181

# Generate with: openssl rand -base64 32
CRON_SECRET=change-me-to-a-random-string

# ─── Public URLs ──────────────────────────────────────────
# Set these to your actual domain in production
NEXT_PUBLIC_URL=http://localhost:3002
NEXT_PUBLIC_STATUS_PAGE_BASE_URL=http://localhost:3003
# Domain for subdomain-based status page routing (must match hostname above)
# STATUS_PAGE_DOMAIN=localhost

# NextAuth callback URL (set to your public domain if behind a reverse proxy)
# NEXTAUTH_URL=https://status.example.com

# ─── Email (Optional) ────────────────────────────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=alerts@example.com

# ─── Port Overrides ──────────────────────────────────────
# Port overrides go in .env (NOT here). See .env.example.
# Docker Compose reads .env for port bindings, not .env.docker.
