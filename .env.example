# Docker Compose port overrides
# Copy to .env and uncomment to change host ports
# App config goes in .env.docker (see .env.docker.example)
#
# LIBSQL_HTTP_PORT=8080
# LIBSQL_GRPC_PORT=5001
# TINYBIRD_PORT=7181
# SERVER_PORT=3001
# DASHBOARD_PORT=3002
# STATUS_PAGE_PORT=3003
# CHECKER_PORT=8082
# PRIVATE_LOCATION_PORT=8081
